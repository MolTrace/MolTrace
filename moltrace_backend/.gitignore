# Local environment and secrets
.env
.env.*
!.env.example
!.env.*.example
!.env.render.example

# Python caches and virtualenvs
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.venv/
venv/
torch_env/
.uv-cache/

# Local databases and runtime state
*.sqlite
*.sqlite3
*.db
nmrcheck.sqlite3
.nmrcheck/

# Scientific/raw artifacts and generated archives
raw_data_vault/
artifacts/
uploads/
exports/
tmp/
/*.zip

# Logs and OS noise
*.log
.DS_Store
**/.DS_Store

# NMRNet / JTF-Net model weights / scalers + NMRShiftDB2-derived KB tables.
# NEVER commit model weights or any table derived from NMRShiftDB2 (see NOTICE).
# Default weight caches live outside the repo (~/.cache/moltrace/nmrnet/ and
# ~/.cache/moltrace/jtfnet/); JTF-Net protein-domain weights are downloaded by
# the end user from the authors' Nat. Commun. 2025 release, not redistributed.
*.pt
*.ss
*.ckpt
hose_kb*.json
moltrace_nmrnet_cache/
moltrace_jtfnet_cache/

# FAISS spectrum-similarity indices + embeddings DERIVED from NMRShiftDB2 are
# CC-BY-SA derivatives (ShareAlike -- see NOTICE); NEVER commit them. Build
# locally with scripts/build_similarity_index.py.
*.faiss
*.faiss.ids.json
spectrum_similarity_index/

# Audit trail (Prompt 12 / 21 CFR Part 11 support): append-only logs are
# customer records, not source -- NEVER commit them. The org HMAC signing key is
# a secret supplied via $MOLTRACE_AUDIT_HMAC_KEY (no key file is committed).
*.audit.jsonl
audit_trail*.jsonl
moltrace_audit_log/
audit_exports/
