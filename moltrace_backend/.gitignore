# Local environment and secrets
.env
.env.*
!.env.example
!.env.*.example
!.env.render.example

# Python caches and virtualenvs
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.venv/
venv/
torch_env/
.uv-cache/

# Local databases and runtime state
*.sqlite
*.sqlite3
*.db
nmrcheck.sqlite3
.nmrcheck/

# Scientific/raw artifacts and generated archives
raw_data_vault/
artifacts/
uploads/
exports/
tmp/
/*.zip

# Logs and OS noise
*.log
.DS_Store
**/.DS_Store

# NMRNet / JTF-Net model weights / scalers + NMRShiftDB2-derived KB tables.
# NEVER commit model weights or any table derived from NMRShiftDB2 (see NOTICE).
# Default weight caches live outside the repo (~/.cache/moltrace/nmrnet/ and
# ~/.cache/moltrace/jtfnet/); JTF-Net protein-domain weights are downloaded by
# the end user from the authors' Nat. Commun. 2025 release, not redistributed.
*.pt
*.ss
*.ckpt
hose_kb*.json
moltrace_nmrnet_cache/
moltrace_jtfnet_cache/

# FAISS spectrum-similarity indices + embeddings DERIVED from NMRShiftDB2 are
# CC-BY-SA derivatives (ShareAlike -- see NOTICE); NEVER commit them. Build
# locally with scripts/build_similarity_index.py.
*.faiss
*.faiss.ids.json
spectrum_similarity_index/

# Audit trail (Prompt 12 / 21 CFR Part 11 support): append-only logs are
# customer records, not source -- NEVER commit them. The org HMAC signing key is
# a secret supplied via $MOLTRACE_AUDIT_HMAC_KEY (no key file is committed).
*.audit.jsonl
audit_trail*.jsonl
moltrace_audit_log/
audit_exports/

# Phase 0 foundation (Prompt 19) infra artifacts -- run stores, dataset caches,
# and DVC remotes are reproducible outputs / large blobs, NEVER source.
# MLflow (and the native run store) local run directories.
mlruns/
mlartifacts/
moltrace_runs/
# DVC: this repo never tracks data blobs; the local cache, scratch tmp, and any
# throwaway local remote used by tests/restore are artifacts.
/.dvc/cache/
/.dvc/tmp/
.dvc_tmp_remote/
moltrace_data_store/
# Great Expectations scratch (uncommitted validations / data docs).
gx/uncommitted/
great_expectations/uncommitted/

# AI model registry + inference router (Prompt 13). The registry persists only
# content addresses (SHA-256) + lineage metadata -- never weights/blobs/DB dumps.
# Production uses PostgreSQL; local/test runs use SQLite (already covered by the
# *.db / *.sqlite patterns above). Listed explicitly for clarity.
ai_model_registry*.db
*.registry.db

# Phase 3 public-datasets pipeline (Prompt 20): the normalized corpus, the
# content-addressed split store, and the train/val/test JSONL are large data
# artifacts versioned via DVC / the content-addressed remote -- NEVER committed
# (licences such as CC-BY-SA and the non-redistributable SDBS / METLIN also
# forbid blind redistribution). The Prompt 19 `moltrace_data_store/` + `.dvc/`
# patterns above already cover the default remotes; these add corpus working dirs.
moltrace_corpus/
corpus_store/
*.corpus.jsonl
