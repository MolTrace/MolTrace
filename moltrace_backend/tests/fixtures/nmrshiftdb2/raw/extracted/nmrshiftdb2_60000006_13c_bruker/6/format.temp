		INV_REL	"SP[5]=SP5"
		UNIT	"dB"
		FORMAT	"%14.2f dB"
		TEXT	" "
END
NAME		SPNAM4
		TEXT	" "
END
NAME		SPNAM5
		TEXT	" "
END
T_NAME		SPOAL4
		TYPE	R32
		CLASS	ACQU
		SUBRANGE -1.0 1.0
		REL	"SPOAL4=SPOAL[4]"
		INV_REL	"SPOAL[4]=SPOAL4"
		FORMAT	"%14.3f"
