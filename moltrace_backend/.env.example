# Copy to `.env` when running the backend locally (optional; defaults work without it).
# See `src/nmrcheck/settings.py` for all variables.

# Comma-separated administrator emails (case-insensitive). These users get is_admin on
# register/sign-up and are promoted on login if the DB was out of sync. No admin is
# granted unless this is set (the code default is empty).
ADMIN_EMAILS=admin@example.com
