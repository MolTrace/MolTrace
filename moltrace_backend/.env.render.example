APP_ENV=production
DEBUG=false
LOG_LEVEL=info
PYTHON_VERSION=3.13.5
DATABASE_URL=postgresql://user:password@host:5432/nmrcheck
REDIS_URL=redis://default:password@host:6379/0
QUEUE_NAME=nmrcheck
HEALTHCHECK_PATH=/health
BASE_URL=https://your-app.onrender.com
ACCESS_TOKEN_TTL_MINUTES=10080
REQUIRE_VERIFIED_EMAIL=true
EMAIL_VERIFICATION_TTL_MINUTES=4320
PASSWORD_RESET_TTL_MINUTES=60
EMAIL_BACKEND=database
EMAIL_FROM=noreply@yourdomain.com
ALLOWED_ORIGINS=https://your-render-service.onrender.com
ALLOWED_UPLOAD_TYPES=csv,json
API_KEY=replace-me

# Comma-separated; must include every admin. REQUIRED to have any admin (no code default).
ADMIN_EMAILS=admin@example.com
DEFAULT_ANALYSIS_MINUTES_SAVED=7
DEFAULT_VALIDATION_MINUTES_SAVED=2
REVIEW_QUEUE_LIMIT=100
AUDIT_LOG_LIMIT=200
RELEASE_STAGE=week39-lcms-consensus-unified-confidence-bridge
RELEASE_VERSION=0.39.0

# Immutable raw Bruker and Varian/Agilent FID vault
RAW_VAULT_DIR=raw_data_vault
RAW_ARCHIVE_MAX_BYTES=2147483648
RAW_ARCHIVE_MAX_FILES=5000
RAW_ARCHIVE_ALLOWED_EXTENSIONS=.zip,.tar.gz,.tgz
RAW_ARCHIVE_IMMUTABLE=true
RAW_ARCHIVE_REQUIRE_HASH_VERIFICATION=true

# Guarded Week 25 processed 2D NMR evidence engine
ENABLE_2D_NMR=true
ENABLE_2D_CONTOUR_PREVIEW=true
ENABLE_RAW_2D_FID_BETA=false

# Raw Bruker and Varian/Agilent FID processing needs:
# uv sync --extra fid
